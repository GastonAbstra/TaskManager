{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "DotnetLabHostApi": {
        "ClusterId": "DotnetLabHostApiCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "DotnetLabClient": {
        "ClusterId": "DotnetLabClientCluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "DotnetLabHostApiCluster": {
        "Destinations": {
          "DotnetLabHostApiDestination": {
            "Address": "https://localhost:7277"
          }
        }
      },
      "DotnetLabClientCluster": {
        "Destinations": {
          "DotnetLabClientDestination": {
            "Address": "http://localhost:4200"
          }
        }
      }
    }
  }
}
